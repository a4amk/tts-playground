# ==========================================
# TTS Playground Global Configuration
# ==========================================

# Use this file to set environment variables that control
# the behavior of the TTS Playground and its engine plugins.

# ------------------------------------------
# Hugging Face Settings
# ------------------------------------------
# Set to '1' to force Hugging Face to use localized caching only (offline mode).
HF_HUB_OFFLINE=0

# Specifies the root directory for Hugging Face cache.
# Example: ./models_data/hf_cache
# HF_HOME=

# ------------------------------------------
# Hardware Settings
# ------------------------------------------
# Set to 'True' to force models to ignore CUDA/GPU and run on CPU.
USE_CPU_ONLY=False

# ------------------------------------------
# Application Server Settings
# ------------------------------------------
# Port for the uvicorn server.
TTS_PORT=7860

# The default engine to select in the UI.
DEFAULT_TTS_ENGINE=kokoro

# ZipVoice Specific: Use ONNX for faster CPU inference (Default: True)
ZIPVOICE_USE_ONNX=True
